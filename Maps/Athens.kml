        <Placemark>
          <name>Grosvenor West</name>
          <description>
            <![CDATA[<p><img src="https://www.ohio.edu/sites/default/files/2023-01/20221127_GrosvenorHall_lao_13.jpg" style="max-width:320px;" /></p>
<p><strong>Address:</strong> 16 West Green Dr., Athens, OH 45701</p>
